<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}">
    {% if site.fontStylesheetHref %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="{{ site.fontStylesheetHref }}">
    {% endif %}
    <link rel="stylesheet" href="{{ site.assetCssHref }}">
  </head>
  <body class="{% if bodyClass %}{{ bodyClass }} {% endif %}{{ site.themeClass | default('theme-forest-cream-brown') }} {{ site.fontClass | default('font-roboto') }}">
    {% include "partials/site-header.njk" %}
    <main id="main">
      {% block content %}{% endblock %}
    </main>
    {% include "partials/site-footer.njk" %}
    <script src="{{ site.assetJsHref }}" defer></script>
  </body>
</html>
