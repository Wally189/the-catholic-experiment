{% extends "layouts/base.njk" %}

{% block content %}
  {% set primaryImageSrc = site.gallery[0].image if site.gallery and site.gallery[0] else site.vehicle.image %}
  {% set primaryImageAlt = site.gallery[0].alt if site.gallery and site.gallery[0] else site.vehicle.imageAlt %}
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{{ site.hero.eyebrow }}</p>
        <h1>{{ site.hero.title }}</h1>
        <p class="hero-intro">{{ site.hero.intro }}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="{{ site.hero.primaryCtaHref }}">{{ site.hero.primaryCtaLabel }}</a>
          <a class="button button-secondary" href="{{ site.hero.secondaryCtaHref }}">{{ site.hero.secondaryCtaLabel }}</a>
        </div>
        <ul class="badge-row" aria-label="Core themes">
          {% for badge in site.hero.badges %}
            <li>{{ badge }}</li>
          {% endfor %}
        </ul>
        <div class="hero-note">
          <strong>Placeholder direction</strong>
          <p>Designed for a journal, studio, parish initiative, or other Catholic cultural project that needs a warmer editorial tone.</p>
        </div>
      </div>
      <div class="hero-visuals" aria-label="Project artwork">
        <figure class="frame frame-large motion-panel" data-float="20">
          <img src="{{ primaryImageSrc }}" alt="{{ primaryImageAlt }}">
        </figure>
        <figure class="frame frame-small motion-panel" data-float="28">
          <img src="{{ site.story.image }}" alt="{{ site.story.imageAlt }}">
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-ribbon" aria-label="Sample content pillars">
    <div class="container">
      <div class="service-ribbon">
        {% for item in site.serviceTypes %}
          <span>{{ item }}</span>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section" id="services">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Editorial map</p>
        <h2>Six sample sections for a Catholic publication or studio.</h2>
        <p>The existing card layout now works as a placeholder content architecture for essays, audio, local diaries, liturgical notes, and project-based programming.</p>
      </div>
      <div class="card-grid card-grid-services">
        {% for service in site.services %}
          <article class="service-card">
            <h3>{{ service.title }}</h3>
            <p>{{ service.summary }}</p>
            <span>{{ service.anchorText }}</span>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section section-split" id="about">
    <div class="container split-grid">
      <article class="story-card">
        <p class="eyebrow">Manifesto</p>
        <h2>{{ site.story.title }}</h2>
        <p>{{ site.story.body }}</p>
        <ul class="tick-list">
          {% for point in site.story.highlights %}
            <li>{{ point }}</li>
          {% endfor %}
        </ul>
      </article>
      <figure class="story-image motion-panel" data-float="14">
        <img src="{{ site.story.image }}" alt="{{ site.story.imageAlt }}">
      </figure>
    </div>
  </section>

  <section class="section section-vehicle">
    <div class="container split-grid reverse">
      <figure class="story-image motion-panel" data-float="14">
        <img src="{{ site.vehicle.image }}" alt="{{ site.vehicle.imageAlt }}">
      </figure>
      <article class="story-card story-card-accent">
        <p class="eyebrow">Editorial rhythm</p>
        <h2>{{ site.vehicle.title }}</h2>
        <p>{{ site.vehicle.body }}</p>
        <ul class="tick-list">
          {% for point in site.vehicle.bullets %}
            <li>{{ point }}</li>
          {% endfor %}
        </ul>
      </article>
    </div>
  </section>

  <section class="section" id="gallery">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Visual library</p>
        <h2>Placeholder artwork with warmth, texture, and liturgical atmosphere.</h2>
        <p>These SVGs are only stand-ins, but they demonstrate a more deliberate Catholic mood than generic stock photography or recycled business imagery.</p>
      </div>
      <div class="gallery-grid">
        {% for item in site.gallery %}
          {% if not loop.first %}
            <figure class="gallery-card motion-panel" data-float="10">
              <img src="{{ item.image }}" alt="{{ item.alt }}">
              <figcaption>
                <strong>{{ item.title }}</strong>
                <span>{{ item.caption }}</span>
              </figcaption>
            </figure>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section section-faq" id="faq">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Practical questions</p>
        <h2>Common questions about the placeholder concept</h2>
      </div>
      <div class="faq-grid">
        {% for item in site.faq %}
          <details class="faq-item">
            <summary>{{ item.question }}</summary>
            <p>{{ item.answer }}</p>
          </details>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section section-contact" id="contact">
    <div class="container contact-shell">
      <div class="contact-copy">
        <p class="eyebrow">Plan the real launch</p>
        <h2>Use placeholder details now, then swap in the real team later.</h2>
        <p>{{ site.contact.locationSummary }}</p>
      </div>
      <div class="contact-cards">
        <article class="contact-card">
          <span>Phone</span>
          {% if site.contact.phoneHref %}
            <a href="{{ site.contact.phoneHref }}">{{ site.contact.phoneDisplay }}</a>
          {% else %}
            <strong>{{ site.contact.phoneDisplay }}</strong>
          {% endif %}
        </article>
        <article class="contact-card">
          <span>Email</span>
          <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
        </article>
        {% if site.contact.whatsappLink %}
          <article class="contact-card">
            <span>WhatsApp</span>
            <a href="{{ site.contact.whatsappLink }}" target="_blank" rel="noreferrer">{{ site.contact.whatsappLink | replace("https://", "") | replace("http://", "") }}</a>
          </article>
        {% endif %}
        {% if site.contact.facebookLink %}
          <article class="contact-card">
            <span>Facebook</span>
            <a href="{{ site.contact.facebookLink }}" target="_blank" rel="noreferrer">{{ site.contact.facebookLink | replace("https://", "") | replace("http://", "") | replace("www.", "") }}</a>
          </article>
        {% endif %}
        <article class="contact-card">
          <span>Location</span>
          <strong>{{ site.contact.addressLabel }}</strong>
        </article>
        <article class="contact-card">
          <span>Hours</span>
          <strong>{{ site.contact.hours }}</strong>
        </article>
      </div>
    </div>
  </section>
{% endblock %}
