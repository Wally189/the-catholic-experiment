{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:public",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/logout",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/api/:path*",
      "destination": "/",
      "permanent": false
    }
  ]
}
