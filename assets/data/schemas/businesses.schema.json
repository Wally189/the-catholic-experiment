{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecatholicexperiment.local/schemas/businesses.schema.json",
  "title": "Business",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": ["id", "name", "slug", "business_type", "country", "verification_status", "sources"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "slug": { "type": "string" },
      "business_type": { "type": "string", "enum": ["publisher", "retail", "hospitality", "professional-service", "maker", "travel", "other"] },
      "country": { "type": "string" },
      "region": { "type": "string" },
      "locality": { "type": "string" },
      "website_url": { "type": "string", "format": "uri" },
      "summary": { "type": "string" },
      "search_terms": { "$ref": "entity-common.schema.json#/$defs/stringList" },
      "verification_status": { "$ref": "entity-common.schema.json#/$defs/verification" },
      "sources": {
        "type": "array",
        "items": { "$ref": "entity-common.schema.json#/$defs/source" },
        "minItems": 1
      }
    }
  }
}
