{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecatholicexperiment.local/schemas/organisations.schema.json",
  "title": "Organisation",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": ["id", "name", "slug", "organisation_type", "country_scope", "verification_status", "sources"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "slug": { "type": "string" },
      "organisation_type": { "type": "string", "enum": ["charity", "education-service", "media", "apostolate", "other"] },
      "country_scope": { "$ref": "entity-common.schema.json#/$defs/stringList" },
      "website_url": { "type": "string", "format": "uri" },
      "summary": { "type": "string" },
      "search_terms": { "$ref": "entity-common.schema.json#/$defs/stringList" },
      "verification_status": { "$ref": "entity-common.schema.json#/$defs/verification" },
      "sources": {
        "type": "array",
        "items": { "$ref": "entity-common.schema.json#/$defs/source" },
        "minItems": 1
      }
    }
  }
}
